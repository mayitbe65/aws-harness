{
  "name": "error-qa-cdk",
  "version": "1.0.0",
  "description": "AWS CDK infrastructure for 错题宝 full-stack application",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "cdk:init": "cdk init app --language typescript",
    "cdk:diff": "cdk diff",
    "cdk:synth": "cdk synth",
    "cdk:deploy:dev": "cdk deploy ErrorQaStackDev --require-approval never",
    "cdk:deploy:prod": "cdk deploy ErrorQaStackProd --require-approval never",
    "cdk:destroy:dev": "cdk destroy ErrorQaStackDev --force",
    "cdk:destroy:prod": "cdk destroy ErrorQaStackProd --force",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "aws-cdk-lib": "^2.130.0",
    "constructs": "^10.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "aws-cdk": "^2.130.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1"
  }
}
